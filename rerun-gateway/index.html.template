<!doctype html>
<!--
  Rerun Gateway - Custom viewer page with gRPC-web MITM fetch interceptor.
  This rewrites gRPC-web requests from /rerun.* to __BASE_PATH__/rerun.*
  so they route through the App CRD's path.
-->
<html>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />

  <head>
    <base href="__BASE_PATH__/" />
    <title>Rerun Viewer</title>
    <style>
      html {
        touch-action: manipulation;
      }
      body {
        background: #0d1011;
      }
      html, body {
        overflow: hidden;
        margin: 0 !important;
        padding: 0 !important;
        height: 100%;
        width: 100%;
      }
      canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
      }
      .centered {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        color: #cad8de;
        font-family: "Inter", sans-serif;
        font-weight: 500;
      }
      .hidden { opacity: 0; visibility: hidden; }
      .visible { opacity: 1; visibility: visible; }
    </style>

    <script>
      // =======================================================
      // MITM Fetch Interceptor for gRPC-web
      // =======================================================
      // The Rerun WASM viewer sends gRPC-web requests to the host
      // ROOT (e.g. /rerun.Service/Method or /proxy). But the App
      // CRD only allows traffic at __BASE_PATH__/*. So we intercept
      // fetch() and rewrite these URLs to go through our base path.
      //
      // Also includes a Safari workaround: Safari does not support
      // ReadableStream as a fetch() request body. We buffer it into
      // a Uint8Array before sending (safe for gRPC-web requests
      // which are small).
      // =======================================================

      (function() {
        const BASE_PATH = '__BASE_PATH__';
        const originalFetch = window.fetch;

        // Helper: buffer a ReadableStream into a single Uint8Array
        function bufferStream(stream) {
          var reader = stream.getReader();
          var chunks = [];
          return new Promise(function(resolve, reject) {
            function pump() {
              reader.read().then(function(result) {
                if (result.done) {
                  var totalLength = chunks.reduce(function(acc, c) { return acc + c.length; }, 0);
                  var buffer = new Uint8Array(totalLength);
                  var offset = 0;
                  chunks.forEach(function(chunk) {
                    buffer.set(chunk, offset);
                    offset += chunk.length;
                  });
                  resolve(buffer);
                } else {
                  chunks.push(result.value);
                  pump();
                }
              }).catch(reject);
            }
            pump();
          });
        }

        window.fetch = function(input, init) {
          var url;
          var isRequest = (input instanceof Request);
          var originalRequest = isRequest ? input : null;

          if (isRequest) {
            url = input.url;
          } else {
            url = String(input);
          }

          // Check if this is a rerun request at the root that needs rewriting
          try {
            var parsed = new URL(url, window.location.origin);
            if (parsed.origin === window.location.origin &&
                (parsed.pathname.match(/^\/rerun\./) || parsed.pathname.match(/^\/proxy(\/|$)/))) {
              // Rewrite: /rerun.Service/Method -> BASE_PATH/rerun.Service/Method
              //          /proxy/...            -> BASE_PATH/proxy/...
              var newPath = BASE_PATH + parsed.pathname;
              parsed.pathname = newPath;
              var newUrl = parsed.toString();
              console.debug('[rerun-gateway] Rewriting URL:', url, '->', newUrl);

              // Extract body (may be a ReadableStream from gRPC-web WASM client)
              var body = originalRequest ? originalRequest.body : (init && init.body);

              // Build minimal init for the rewritten request.
              // Only include method, headers, body, and credentials.
              // Avoid copying mode/cache/redirect/referrer from the original request
              // as they can conflict with cloud auth proxies.
              var newInit = {
                method: originalRequest ? originalRequest.method : (init && init.method) || 'POST',
                headers: originalRequest ? originalRequest.headers : (init && init.headers),
                credentials: 'include'
              };

              // If body is a ReadableStream, buffer it first.
              // Chrome requires HTTP/2 for streaming bodies (ERR_ALPN_NEGOTIATION_FAILED)
              // and Safari doesn't support ReadableStream upload at all.
              if (body && typeof body.getReader === 'function') {
                return bufferStream(body).then(function(buffered) {
                  newInit.body = buffered;
                  console.debug('[rerun-gateway] Sending buffered request:', newUrl, 'body size:', buffered.length);
                  return originalFetch.call(this, newUrl, newInit).catch(function(err) {
                    console.error('[rerun-gateway] Fetch failed:', err.message, 'url:', newUrl);
                    throw err;
                  });
                }.bind(this));
              }

              newInit.body = body;
              console.debug('[rerun-gateway] Sending request:', newUrl);
              return originalFetch.call(this, newUrl, newInit).catch(function(err) {
                console.error('[rerun-gateway] Fetch failed:', err.message, 'url:', newUrl);
                throw err;
              });
            }
          } catch(e) {
            // If URL parsing fails, pass through unchanged
          }

          return originalFetch.call(this, input, init);
        };

        console.info('[rerun-gateway] Fetch interceptor installed. BASE_PATH=' + BASE_PATH);
      })();
    </script>
  </head>

  <body>
    <div class="centered visible" id="center_text">
      <p>Loading Rerun Viewer...</p>
    </div>
    <canvas id="the_canvas_id" class="hidden"></canvas>

    <script>
      delete WebAssembly.instantiateStreaming;
    </script>

    <script src="re_viewer.js"></script>

    <script>
      function show_center_html(html) {
        var el = document.getElementById("center_text");
        el.innerHTML = html;
        el.classList.remove("hidden");
        el.classList.add("visible");
      }
      function hide_center_html() {
        var el = document.getElementById("center_text");
        el.classList.remove("visible");
        el.classList.add("hidden");
      }
      function show_canvas() {
        var el = document.getElementById("the_canvas_id");
        el.classList.remove("hidden");
        el.classList.add("visible");
      }

      // Auto-set the connection URL if not already present
      (function() {
        const params = new URLSearchParams(window.location.search);
        if (!params.has('url')) {
          const proto = window.location.protocol === 'https:' ? 'rerun+https:' : 'rerun+http:';
          const connUrl = proto + '//' + window.location.host + '/proxy';
          params.set('url', connUrl);
          const newUrl = window.location.pathname + '?' + params.toString();
          window.history.replaceState({}, '', newUrl);
        }
      })();

      function load_wasm() {
        console.debug("Loading WASM...");

        fetch("./re_viewer_bg.wasm")
          .then(function(response) {
            return wasm_bindgen(response);
          })
          .then(on_wasm_loaded)
          .catch(on_wasm_error);
      }

      function on_wasm_loaded() {
        console.debug("WASM loaded. Starting app...");

        const query = new URLSearchParams(window.location.search);
        const options = {
          url: query.getAll("url"),
          manifest_url: query.get("manifest_url"),
          render_backend: query.get("renderer"),
          hide_welcome_screen: true,
          enable_history: true,
          persist: false,
        };

        var handle = new wasm_bindgen.WebHandle(options);

        handle
          .start(document.getElementById("the_canvas_id"))
          .then(function() {
            console.debug("App started.");
            hide_center_html();
            show_canvas();
          })
          .catch(on_wasm_error);
      }

      function on_wasm_error(error) {
        console.error("Failed to start: " + error);
        show_center_html("<p>Error: " + error + "</p>");
      }

      load_wasm();
    </script>
  </body>
</html>
